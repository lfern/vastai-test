# Configuración del proxy y credenciales
# Cambios aquí se aplican con: docker compose up -d  (sin rebuild)

# API key de Vast.ai (https://cloud.vast.ai/account)
VAST_API_KEY=

# ---------------------------------------------------------------------------
# Modelo a cargar en la instancia Vast.ai
REMOTE_MODEL=glm-4.7-flash

# Minutos de inactividad antes de parar la instancia automáticamente
INACTIVITY_MINUTES=15

# Filtros de búsqueda de oferta GPU (sintaxis vastai search offers)
SEARCH_QUERY=dph<0.15 reliability>0.999 gpu_name=RTX_3090 num_gpus=1 gpu_ram>=24 cpu_ram>=32 disk_space>=32

# Imagen Docker a usar en la instancia remota
INSTANCE_IMAGE=vastai/ollama:0.15.4

# Disco en GB para la instancia remota
INSTANCE_DISK_GB=32

# Número máximo de ofertas a intentar si alguna falla
LAUNCH_MAX_RETRIES=5

# Timeout máximo esperando que la instancia arranque (minutos)
# Si no arranca en este tiempo, se abandona y se marca como error
LAUNCH_TIMEOUT_MIN=8

# Segundos entre mensajes de keepalive mientras arranca (para no hacer timeout al cliente)
STATUS_INTERVAL_SEC=8

# Segundos entre polls de estado durante el arranque
# Más bajo = logs más frecuentes, más llamadas a la API de Vast.ai
POLL_INTERVAL_SEC=15
